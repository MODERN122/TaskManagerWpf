<Application x:Class="TaskManagerWpf.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TaskManagerWpf.App.Converters"
             >
    <Application.Resources>
        <converters:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
        <converters:NullableDateToStringConverter x:Key="NullableDateToStringConverter" />
        <converters:OverdueToBrushConverter x:Key="OverdueToBrushConverter" />

        <!-- Global DatePicker format: dd.MM.yyyy (via ru-RU ShortDatePattern) -->
        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="Language" Value="ru-RU" />
            <Setter Property="SelectedDateFormat" Value="Short" />
        </Style>

        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Language" Value="ru-RU" />
        </Style>

        <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Padding" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="TaskRowBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </Application.Resources>
</Application>
