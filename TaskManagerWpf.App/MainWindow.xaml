<Window x:Class="TaskManagerWpf.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManagerWpf.App"
        xmlns:vm="clr-namespace:TaskManagerWpf.App.ViewModels"
        mc:Ignorable="d"
        Title="Task Manager" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="RoundIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D5DB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" />
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2" />
                            <TextBlock
                                x:Name="Watermark"
                                Margin="12,0,12,0"
                                Foreground="#9CA3AF"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"
                                Text="Введите название / описание задачи"
                                Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value="" />
                                    <Condition Property="IsKeyboardFocused" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="22"
            FontWeight="SemiBold"
            Text="Task Manager" />

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: scrollable toolbar with arrows -->
            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    x:Name="ScrollLeftButton"
                    Style="{StaticResource RoundIconButtonStyle}"
                    Click="ScrollToolbarLeft_Click"
                    ToolTip="Прокрутить влево">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE76B;" />
                </Button>

                <ScrollViewer
                    x:Name="ToolbarScrollViewer"
                    Grid.Column="1"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Disabled"
                    CanContentScroll="False"
                    Loaded="ToolbarScrollViewer_Loaded"
                    ScrollChanged="ToolbarScrollViewer_ScrollChanged"
                    SizeChanged="ToolbarScrollViewer_SizeChanged">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Margin="0,0,8,0" Padding="12,6" Content="➕ Добавить" Command="{Binding AddTaskCommand}" />
                        <Button Margin="0,0,8,0" Padding="12,6" Content="✏️ Редактировать" Command="{Binding EditSelectedTaskCommand}" />
                        <Button Margin="0,0,8,0" Padding="12,6" Content="🗑️ Удалить" Command="{Binding DeleteSelectedTaskCommand}" />
                        <Button Margin="0,0,16,0" Padding="12,6" Content="✅ Переключить статус" Command="{Binding ToggleStatusCommand}" />

                        <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="Фильтр:" />
                        <ComboBox
                            Width="105"
                            Margin="0,0,12,0"
                            ItemsSource="{Binding StatusFilters}"
                            SelectedItem="{Binding SelectedStatusFilter}" />

                        <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="Сортировка:" />
                        <ComboBox
                            Width="210"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding SortModes}"
                            SelectedItem="{Binding SelectedSortMode}" />
                    </StackPanel>
                </ScrollViewer>

                <Button
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    x:Name="ScrollRightButton"
                    Style="{StaticResource RoundIconButtonStyle}"
                    Click="ScrollToolbarRight_Click"
                    ToolTip="Прокрутить вправо">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE76C;" />
                </Button>
            </Grid>

            <!-- Right: pinned search + refresh -->
            <DockPanel Grid.Column="1" LastChildFill="False" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Style="{StaticResource RoundIconButtonStyle}"
                    Command="{Binding RefreshCommand}"
                    ToolTip="Обновить">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE72C;" />
                </Button>

                <TextBox
                    Width="320"
                    Style="{StaticResource SearchBoxStyle}"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Поиск по названию и описанию" />
            </DockPanel>
        </Grid>

        <ListView
            Grid.Row="2"
            ItemsSource="{Binding TasksView}"
            SelectedItem="{Binding SelectedTask}"
            VirtualizingPanel.IsVirtualizing="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                    <Border Style="{StaticResource TaskRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Title}" />
                                    <Border
                                        Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="10"
                                        Background="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding Priority}" />
                                    </Border>
                                    <Border
                                        Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="10"
                                        Background="#6B7280">
                                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding Status}" />
                                    </Border>
                                </StackPanel>

                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="#4B5563"
                                    TextTrimming="CharacterEllipsis"
                                    Text="{Binding Description}" />

                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock Foreground="#6B7280" Text="Создано: " />
                                    <TextBlock Foreground="#111827" Text="{Binding CreatedAt, Converter={StaticResource NullableDateToStringConverter}}" />

                                    <TextBlock Margin="18,0,0,0" Foreground="#6B7280" Text="Срок: " />
                                    <TextBlock
                                        Foreground="{Binding IsOverdue, Converter={StaticResource OverdueToBrushConverter}}"
                                        Text="{Binding DueDate, Converter={StaticResource NullableDateToStringConverter}}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Foreground="{Binding IsOverdue, Converter={StaticResource OverdueToBrushConverter}}" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="OverdueLabel" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StatusBar Grid.Row="3" Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
