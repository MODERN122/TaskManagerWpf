<Window x:Class="TaskManagerWpf.App.Views.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManagerWpf.App.Views"
        mc:Ignorable="d"
        Title="Задача"
        Height="520"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        local:DialogCloser.DialogResult="{Binding DialogResult}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Редактирование задачи" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Margin="0,0,0,6" Text="Title *" />
            <TextBox
                Text="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                Height="28" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Margin="0,0,0,6" Text="Description" />
            <TextBox
                Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                Height="84"
                AcceptsReturn="True"
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Margin="0,0,0,6" Text="Status" />
                <ComboBox
                    ItemsSource="{Binding StatusValues}"
                    SelectedItem="{Binding Status}"
                    Height="28" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,6" Text="Priority" />
                <ComboBox
                    ItemsSource="{Binding PriorityValues}"
                    SelectedItem="{Binding Priority}"
                    Height="28" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,14,0,0">
            <TextBlock Margin="0,0,0,6" Text="DueDate" />
            <DatePicker
                SelectedDate="{Binding DueDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                Height="28" />
        </StackPanel>

        <Border Grid.Row="5" Margin="0,14,0,0" Background="#FFF7ED" CornerRadius="6" Padding="10">
            <TextBlock Foreground="#9A3412" TextWrapping="Wrap">
                <Run Text="Правила:" />
                <LineBreak />
                <Run Text="• Title обязателен" />
                <LineBreak />
                <Run Text="• При создании DueDate не может быть в прошлом" />
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Padding="16,6" Margin="0,0,8,0" Content="Отмена" Command="{Binding CancelCommand}" />
            <Button Padding="16,6" Content="Сохранить" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>

