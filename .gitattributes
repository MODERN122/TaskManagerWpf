# Auto detect text files and normalize them
* text=auto

# Visual Studio / .NET (Windows-friendly CRLF)
*.sln           text eol=crlf
*.cs            text eol=crlf
*.csproj        text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf
*.xaml          text eol=crlf
*.xml           text eol=crlf
*.config        text eol=crlf
*.json          text eol=crlf
*.editorconfig  text eol=crlf
*.gitattributes text eol=crlf
*.gitignore     text eol=crlf
*.md            text eol=crlf

# Windows scripts
*.ps1           text eol=crlf
*.psm1          text eol=crlf
*.psd1          text eol=crlf
*.cmd           text eol=crlf
*.bat           text eol=crlf

# Unix scripts (prefer LF)
*.sh            text eol=lf

# Binary files
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.bmp           binary
*.webp          binary

*.pdf           binary
*.zip           binary
*.7z            binary

*.exe           binary
*.dll           binary
*.pdb           binary

*.pfx           binary
*.snk           binary

*.ttf           binary
*.otf           binary
*.woff          binary
*.woff2         binary
